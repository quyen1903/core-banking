# Local development only. Do not use these values outside a disposable local
# PostgreSQL instance.

SPRING_PROFILES_ACTIVE=dev
spring.profiles.active=dev
SERVER_PORT=8080

QUINNBANK_DEV_DB_URL=jdbc:postgresql://localhost:5432/quinnbank
QUINNBANK_DEV_DB_USERNAME=postgres
QUINNBANK_DEV_DB_PASSWORD=postgres

QUINNBANK_DB_POOL_MAX_SIZE=10
QUINNBANK_DB_POOL_MIN_IDLE=2

# Local bootstrap API user for dev/test only.
QUINNBANK_SECURITY_LOCAL_BOOTSTRAP_USERNAME=local-admin
QUINNBANK_SECURITY_LOCAL_BOOTSTRAP_PASSWORD=replace-me-local-only
QUINNBANK_SECURITY_LOCAL_BOOTSTRAP_AUTHORITIES=EMPLOYEE_CREATE,IDENTITY_ACCOUNT_CREATE
